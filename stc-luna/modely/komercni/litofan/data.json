{
  "id": "helenka",

  "name": "Projekt Helenka",

  "description": "Konfigurátor litofánových projektů.",

  "valueFactor": 1.0,

  "groups": [

    {
      "id": "plates",

      "name": "Litofánové destičky",

      "type": "multiple",

      "defaultQuantity": 1,

      "min": 0,

      "max": 20,

      "modules": [

        {
          "id": "plate",

          "name": "Litofánová destička",

          "source": "plate-data.json",

          "allowPhoto": true,

          "allowOrientation": true,

          "allowPreviewMode": true
        }

      ]
    },

    {
      "id": "frames",

      "name": "Rámečky",

      "type": "multiple",

      "defaultQuantity": 0,

      "min": 0,

      "max": 20,

      "modules": [

        {
          "id": "basic",

          "name": "Basic",

          "source": "frame-data.json",

          "allowMaterial": true,

          "allowColor": true
        }

      ],

      "addons": [

        {
          "id": "led",

          "name": "LED panel",

          "source": "led-panels.json"
        },

        {
          "id": "adapter",

          "name": "Síťový adaptér",

          "source": "adapters.json"
        }

      ]
    }

  ]
}